aws_region   = "eu-west-2"
project_name = "offerzen-aws-assessment"
environment  = "dev"

vpc_cidr = "10.0.0.0/16"
public_subnets = {
  "eu-west-2a" = "10.0.1.0/24"
  "eu-west-2b" = "10.0.2.0/24"
}
private_subnets = {
  "eu-west-2a" = "10.0.11.0/24"
  "eu-west-2b" = "10.0.12.0/24"
}
create_internet_gateway = true

load_balancers = {
  ui = {
    internal    = false
    subnet_type = "public"
    enable_http = true
  }
  backend = {
    internal           = true
    subnet_type        = "private"
    enable_http        = true
    target_port        = 8080
    listener_port      = 8080
    allowed_cidr_blocks = ["10.0.0.0/16"]
  }
}

compute_tiers = {
  ui = {
    instance_type    = "t3.micro"
    min_size         = 1
    max_size         = 1
    desired_capacity = 1
  }
  backend = {
    instance_type    = "t3.micro"
    min_size         = 1
    max_size         = 1
    desired_capacity = 1
  }
}

github_repository = "owner/repo-name"

instance_key_name = null

runner_ssh_cidr_blocks       = []
runner_ssh_security_group_ids = []

additional_tags = {
  Owner = "platform-team"
}

monitoring = {
  enabled                            = true
  alarm_email_endpoint               = null
  alb_5xx_threshold                  = 10
  alb_target_response_time_threshold = 1.5
  unhealthy_host_count_threshold     = 1
  evaluation_periods                 = 2
  period_seconds                     = 300
}

ssm_deployment = {
  enabled                = true
  image_tag              = "latest"
  backend_container_name = "rewards-backend"
  backend_container_port = 3011
  backend_host_port      = 3011
  ui_container_name      = "rewards-ui"
  ui_container_port      = 80
  ui_host_port           = 80
  ui_server_url          = null
}
